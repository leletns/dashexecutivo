# Chave opcional para recursos de IA (Conselheiro / processamento de documentos)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Login · senha única para todos os e-mails em lib/portal-accounts.ts
# Texto da senha: Usuario@2026
# Cole o valor abaixo também na Vercel (Environment Variables) como PORTAL_PASSWORD_HASHES_B64
# ---------------------------------------------------------------------------
PORTAL_PASSWORD_HASHES_

# NextAuth: use o MESMO segredo no desenvolvimento e na Vercel (e no mesmo valor que qualquer fallback em código).
NEXTAUTH_SECRET=portal-executivo-sessao-interna-padrao-defina-nextauth-secret-em-producao
NEXTAUTH_URL=http://localhost:3000

# Supabase (painel ao vivo + gravação em Entrada de dados)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
