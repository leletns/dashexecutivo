# Chave de acesso do provedor de processamento de dados
ANTHROPIC_API_KEY=

# Login Credentials (opcional): Base64 de um JSON { email: bcrypt_hash }.
# Ver npm run auth:bootstrap ou define PORTAL_PASSWORD_HASHES (JSON numa linha).
# PORTAL_PASSWORD_HASHES_B64=

# NextAuth: middleware (Edge) precisa do mesmo segredo que a API.
# Em desenvolvimento pode usar o valor abaixo; em produção use um segredo longo e aleatório.
NEXTAUTH_SECRET=portal-executivo-sessao-interna-padrao-defina-nextauth-secret-em-producao
NEXTAUTH_URL=http://localhost:3000
