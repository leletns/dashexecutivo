# =============================================================================
# Portal Executivo — variáveis de ambiente
# Copie para .env.local no desenvolvimento.
# No Vercel: Settings → Environment Variables → cole cada linha abaixo.
# =============================================================================

# ---------------------------------------------------------------------------
# NextAuth — OBRIGATÓRIO
# ---------------------------------------------------------------------------
# Gere um segredo forte: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-aleatorio-longo

# Desenvolvimento: http://localhost:3000
# Vercel: https://SEU-DOMINIO.vercel.app  (sem barra no final)
NEXTAUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Senhas dos logins — OBRIGATÓRIO
# Valor pré-gerado abaixo = senha "Usuario@2026" para todos os usuários.
# Para gerar novos hashes: npm run auth:bootstrap
# ---------------------------------------------------------------------------
PORTAL_PASSWORD_HASHES_

# ---------------------------------------------------------------------------
# Supabase — OBRIGATÓRIO para o módulo Financeiro e dados ao vivo
# 1. Crie um projeto em https://supabase.com
# 2. Execute supabase/schema.sql no SQL Editor do projeto
# 3. Copie as chaves em Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key_aqui...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_aqui...

# ---------------------------------------------------------------------------
# Anthropic — OPCIONAL
# Sem esta chave: suporte via chat usa fallback local; importação de planilha
# funciona sem detecção inteligente de colunas.
# Obtenha em https://console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Logins disponíveis (senha padrão: Usuario@2026)
# ---------------------------------------------------------------------------
# ludymilla@portal.com      → executivo  (CEO — visão total)
# financeiro@portal.com     → financeiro (Miguel — preenche módulo financeiro)
# administrativo@portal.com → administrativo
# juridico@portal.com       → jurídico
# contabil@portal.com       → contábil
# marketing@portal.com      → marketing
# eventos@portal.com        → eventos
